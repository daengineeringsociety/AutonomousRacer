# Copy this file to .env.deepracer and update values.

# Example: 192.168.0.42 (Wi-Fi AP mode) or your LAN IP
DEEPRACER_HOST=172.17.0.1

# DeepRacer Linux username
DEEPRACER_USER=ubuntu

# SSH port on DeepRacer
DEEPRACER_PORT=22

# Optional private key path inside the container (mounted via ~/.ssh)
# Example: /home/druser/.ssh/id_rsa
DEEPRACER_KEY=
